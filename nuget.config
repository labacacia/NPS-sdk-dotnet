<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="nexus-private" value="https://nexus.ts01.starfield.com.au/repository/nuget-hosted/" />
  </packageSources>
  <!-- NSec.Cryptography is only on nuget.org; nexus-private returns 404 for it.
       Map it explicitly so NuGet does not query the private feed. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="NSec.Cryptography" />
      <package pattern="*" />
    </packageSource>
    <packageSource key="nexus-private">
      <package pattern="NPS.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
